{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/", "destination": "/landing.html" },
    { "source": "/inscription", "destination": "/inscription.html" },
    { "source": "/app", "destination": "/app-commercant.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/catalogue", "destination": "/catalogue.html" },
    { "source": "/panier", "destination": "/panier.html" },
    { "source": "/compte", "destination": "/compte.html" },
    { "source": "/notre-histoire", "destination": "/notre-histoire.html" },
    { "source": "/cgv", "destination": "/cgv.html" },
    { "source": "/confidentialite", "destination": "/confidentialite.html" },
    { "source": "/charte", "destination": "/charte.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" },

    { "source": "/ambassadeur", "destination": "/ambassadeur.html" },
    { "source": "/ambassadeur/dashboard", "destination": "/ambassadeur-dashboard.html" },
    { "source": "/ambassadeur/creer-demo", "destination": "/ambassadeur-creer-demo.html" },
    { "source": "/ambassadeur/conditions", "destination": "/ambassadeur-conditions.html" },
    { "source": "/demo/:demo_slug", "destination": "/demo.html?slug=:demo_slug" },

    { "source": "/:slug", "destination": "/boutique.html?slug=:slug" },
    { "source": "/:slug/", "destination": "/boutique.html?slug=:slug" },
    { "source": "/:slug/manifest.json", "destination": "/manifest-client.json" },
    { "source": "/:slug/catalogue", "destination": "/catalogue.html?slug=:slug" },
    { "source": "/:slug/panier", "destination": "/panier.html?slug=:slug" },
    { "source": "/:slug/compte", "destination": "/compte.html?slug=:slug" },
    { "source": "/:slug/notre-histoire", "destination": "/notre-histoire.html?slug=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
